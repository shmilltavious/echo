      <Item class="LocalScript" referent="30">
        <Properties>
          <string name="Name">Client</string>
          <string name="Source"><![CDATA[-- Client initialization script
print("Hello world, from client!")

local StarterGui = game:GetService("StarterGui")
local clientFolder = script

local function requireClientModule(name: string)
	local module = clientFolder:WaitForChild(name, 5)
	if not module then
		warn(name .. " failed to load: module missing")
		return nil
	end

	local ok, result = pcall(require, module)
	if not ok then
		warn(name .. " failed to load: " .. tostring(result))
		return nil
	end

	return result
end

local Menu = requireClientModule("Menu")
local SphereVisuals = requireClientModule("SphereVisuals")
local ObjectiveClient = requireClientModule("ObjectiveClient")
local CameraEffects = requireClientModule("CameraEffects")
local AudioFeedback = requireClientModule("AudioFeedback")

local function hidePlayerList()
	pcall(function()
		StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false)
	end)
end

hidePlayerList()
task.spawn(function()
	for _ = 1, 5 do
		task.wait(0.5)
		hidePlayerList()
	end
end)

if not Menu then
	warn("Menu failed to load")
else
	print("Menu loaded")
	Menu.init()
end

if not SphereVisuals then
	warn("SphereVisuals failed to load")
else
	print("SphereVisuals loaded")
end

if not ObjectiveClient then
	warn("ObjectiveClient failed to load")
else
	print("ObjectiveClient loaded")
end

if not CameraEffects then
	warn("CameraEffects failed to load")
else
	print("CameraEffects loaded")
end

if not AudioFeedback then
	warn("AudioFeedback failed to load")
else
	print("AudioFeedback loaded")
end

print("MVP client systems initialized!")
]]></string>
        </Properties>
        <Item class="ModuleScript" referent="31">
          <Properties>
            <string name="Name">AudioFeedback</string>
            <string name="Source"><![CDATA[-- Local audio feedback for movement, breathing, monster proximity, and warnings
local AudioFeedback = {}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")

local player = Players.LocalPlayer
local initialized = false
local lastPlayerStepAt = 0
local lastMonsterStepAt = 0
local lastMonsterPosition: Vector3? = nil

local SOUND_IDS = {
	footstep = "rbxasset://sounds/action_footsteps_plastic.mp3",
	monsterFootstep = "rbxasset://sounds/action_footsteps_plastic.mp3",
	breathing = "rbxassetid://9112854440",
	warning = "rbxassetid://9112854440",
}

local breathLoop: Sound? = nil
local warningLoop: Sound? = nil
local playerStepSound: Sound? = nil
local monsterStepSound: Sound? = nil

local function createSound(name: string, soundId: string, volume: number, looped: boolean): Sound
	local sound = Instance.new("Sound")
	sound.Name = name
	sound.SoundId = soundId
	sound.Volume = volume
	sound.Looped = looped
	sound.RollOffMode = Enum.RollOffMode.InverseTapered
	sound.Parent = SoundService
	return sound
end

local function addHorrorStepEffects(sound: Sound, heavy: boolean)
	local pitch = Instance.new("PitchShiftSoundEffect")
	pitch.Name = "LowPitch"
	pcall(function()
		pitch.Octave = if heavy then 0.55 else 0.72
	end)
	pitch.Parent = sound

	local eq = Instance.new("EqualizerSoundEffect")
	eq.Name = "DullRoomTone"
	pcall(function()
		eq.LowGain = if heavy then 4 else 2
		eq.MidGain = if heavy then -6 else -3
		eq.HighGain = if heavy then -18 else -12
	end)
	eq.Parent = sound

	local reverb = Instance.new("ReverbSoundEffect")
	reverb.Name = "ShortConcreteReverb"
	pcall(function()
		reverb.DecayTime = if heavy then 1.15 else 0.65
		reverb.Density = 0.45
		reverb.Diffusion = 0.65
		reverb.DryLevel = 0
		reverb.WetLevel = if heavy then -18 else -24
	end)
	reverb.Parent = sound
end

local function getCharacterRoot(): BasePart?
	local character = player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(): Humanoid?
	local character = player.Character
	return character and character:FindFirstChildOfClass("Humanoid")
end

local function getMonsterRoot(): BasePart?
	local monster = workspace:FindFirstChild("Monster") or workspace:FindFirstChild("Rig")
	return monster and monster:FindFirstChild("HumanoidRootPart")
end

local function ensureSounds()
	if not playerStepSound then
		playerStepSound = createSound("PlayerStep", SOUND_IDS.footstep, 0.18, false)
		addHorrorStepEffects(playerStepSound, false)
	end
	if not monsterStepSound then
		monsterStepSound = createSound("MonsterStep", SOUND_IDS.monsterFootstep, 0.32, false)
		addHorrorStepEffects(monsterStepSound, true)
		monsterStepSound.PlaybackSpeed = 0.52
	end
	if not breathLoop then
		breathLoop = createSound("PlayerBreathingLoop", SOUND_IDS.breathing, 0, true)
		breathLoop.PlaybackSpeed = 0.62
		breathLoop:Play()
	end
	if not warningLoop then
		warningLoop = createSound("MonsterWarningLoop", SOUND_IDS.warning, 0, true)
		warningLoop.PlaybackSpeed = 0.48
		warningLoop:Play()
	end
end

local function updatePlayerFootsteps(now: number, humanoid: Humanoid)
	if humanoid.FloorMaterial == Enum.Material.Air or humanoid.MoveDirection.Magnitude < 0.1 then
		return
	end

	local speed = humanoid.WalkSpeed
	local interval = if speed >= 18 then 0.26 elseif speed <= 8 then 0.58 else 0.42
	if now - lastPlayerStepAt < interval then
		return
	end

	lastPlayerStepAt = now
	if playerStepSound then
		playerStepSound.Volume = if speed >= 18 then 0.24 elseif speed <= 8 then 0.07 else 0.14
		playerStepSound.PlaybackSpeed = if speed >= 18
			then 0.72 + (math.random() * 0.1)
			else 0.58 + (math.random() * 0.12)
		playerStepSound:Play()
	end
end

local function updateBreathing(humanoid: Humanoid, monsterDistance: number?)
	if not breathLoop then return end

	local movingHard = humanoid.MoveDirection.Magnitude > 0.1 and humanoid.WalkSpeed >= 18
	local proximityStress = if monsterDistance then math.clamp(1 - ((monsterDistance - 12) / 46), 0, 1) else 0
	local targetVolume = math.clamp((movingHard and 0.16 or 0.045) + (proximityStress * 0.22), 0.035, 0.32)
	breathLoop.Volume += (targetVolume - breathLoop.Volume) * 0.08
	breathLoop.PlaybackSpeed = 0.62 + (proximityStress * 0.18) + (movingHard and 0.12 or 0)
end

local function updateMonsterAudio(now: number, playerRoot: BasePart?)
	local monsterRoot = getMonsterRoot()
	if not monsterRoot or not playerRoot then
		if warningLoop then
			warningLoop.Volume += (0 - warningLoop.Volume) * 0.08
		end
		return nil
	end

	local distance = (monsterRoot.Position - playerRoot.Position).Magnitude
	local warningIntensity = math.clamp(1 - ((distance - 14) / 56), 0, 1)

	if warningLoop then
		warningLoop.Volume += ((warningIntensity * 0.28) - warningLoop.Volume) * 0.08
		warningLoop.PlaybackSpeed = 0.42 + (warningIntensity * 0.18)
	end

	if lastMonsterPosition then
		local moved = (monsterRoot.Position - lastMonsterPosition).Magnitude
		local stepInterval = math.clamp(0.7 - (warningIntensity * 0.28), 0.28, 0.7)
		if moved > 0.18 and now - lastMonsterStepAt >= stepInterval and monsterStepSound then
			lastMonsterStepAt = now
			monsterStepSound.Volume = math.clamp(warningIntensity * 0.38, 0.05, 0.38)
			monsterStepSound.PlaybackSpeed = 0.46 + (math.random() * 0.1)
			monsterStepSound:Play()
		end
	end

	lastMonsterPosition = monsterRoot.Position
	return distance
end

function AudioFeedback.init()
	if initialized then return end
	initialized = true

	ensureSounds()

	RunService.RenderStepped:Connect(function()
		local now = os.clock()
		local humanoid = getHumanoid()
		local rootPart = getCharacterRoot()
		local monsterDistance = updateMonsterAudio(now, rootPart)

		if humanoid then
			updatePlayerFootsteps(now, humanoid)
			updateBreathing(humanoid, monsterDistance)
		end
	end)
end

return AudioFeedback
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="32">
          <Properties>
            <string name="Name">CameraEffects</string>
            <string name="Source"><![CDATA[-- First-person sprint/jump camera shake only. Tool viewmodels should be equipped by tools.
local CameraEffects = {}

local RunService = game:GetService("RunService")

local InputHandler = require(script.Parent.InputHandler)

local initialized = false
local sprintTime = 0

function CameraEffects.init()
	if initialized then return end
	initialized = true

	RunService:BindToRenderStep("ECHO_CameraEffects", Enum.RenderPriority.Camera.Value + 1, function(dt)
		local camera = workspace.CurrentCamera
		if not camera then return end

		local noise = InputHandler.getNoiseInfo()
		local isSprinting = noise.movementState == "sprint"
		local isJumping = noise.movementState == "jump"
		local targetAlpha = if isSprinting then 1 elseif isJumping then 0.65 else 0
		sprintTime += dt * (1 + targetAlpha)

		local shakeX = math.sin(sprintTime * 17) * 0.022 * targetAlpha
		local shakeRoll = math.sin(sprintTime * 12) * math.rad(0.6) * targetAlpha
		local shakeYaw = math.sin(sprintTime * 9) * math.rad(0.3) * targetAlpha

		camera.CFrame = camera.CFrame * CFrame.new(shakeX, 0, 0) * CFrame.Angles(0, shakeYaw, shakeRoll)
	end)
end

return CameraEffects
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="33">
          <Properties>
            <string name="Name">EquipmentClient</string>
            <string name="Source"><![CDATA[local EquipmentClient = {}

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local InventoryDefinitions = require(ReplicatedStorage.Shared.InventoryDefinitions)

local FLASHLIGHT_ITEM_ID = "Flashlight"
local SLOT_KEYCODES = {
	[Enum.KeyCode.One] = 1,
	[Enum.KeyCode.Two] = 2,
	[Enum.KeyCode.Three] = 3,
	[Enum.KeyCode.KeypadOne] = 1,
	[Enum.KeyCode.KeypadTwo] = 2,
	[Enum.KeyCode.KeypadThree] = 3,
}

local initialized = false
local equippedItemId = FLASHLIGHT_ITEM_ID
local equippedSlot = 1
local capacity = InventoryDefinitions.CAPACITY
local items = {}
local slots = {}
local listeners = {}

local defaultPayload = {
	capacity = InventoryDefinitions.CAPACITY,
	items = {
		{
			id = FLASHLIGHT_ITEM_ID,
			name = InventoryDefinitions.getItem(FLASHLIGHT_ITEM_ID).name,
			weight = InventoryDefinitions.getWeight(FLASHLIGHT_ITEM_ID),
		},
	},
}

local function makeSlotLabel(slotStart: number?, slotEnd: number?): string
	if not slotStart then
		return ""
	end
	if slotEnd and slotEnd ~= slotStart then
		return tostring(slotStart) .. "-" .. tostring(slotEnd)
	end
	return tostring(slotStart)
end

local function findContiguousSlot(weight: number, occupied): number?
	for startSlot = 2, capacity do
		local endSlot = startSlot + weight - 1
		if endSlot > capacity then
			return nil
		end

		local available = true
		for slot = startSlot, endSlot do
			if occupied[slot] then
				available = false
				break
			end
		end

		if available then
			return startSlot
		end
	end

	return nil
end

local function hasEquippedItem(): boolean
	for _, item in ipairs(items) do
		if item.id == equippedItemId then
			return true
		end
	end
	return false
end

local function notify()
	for _, listener in ipairs(listeners) do
		task.spawn(listener, {
			capacity = capacity,
			items = items,
			slots = slots,
			equippedItemId = equippedItemId,
			equippedSlot = equippedSlot,
		})
	end
end

local function applyPayload(payload)
	if typeof(payload) ~= "table" then
		payload = defaultPayload
	end

	capacity = math.max(1, tonumber(payload.capacity) or InventoryDefinitions.CAPACITY)
	local ordered = {}
	local sawFlashlight = false

	if typeof(payload.items) == "table" then
		for _, payloadItem in ipairs(payload.items) do
			local itemId = tostring(payloadItem.id or "")
			if itemId == FLASHLIGHT_ITEM_ID then
				sawFlashlight = true
				table.insert(ordered, 1, payloadItem)
			elseif itemId ~= "" then
				table.insert(ordered, payloadItem)
			end
		end
	end

	if not sawFlashlight then
		table.insert(ordered, 1, defaultPayload.items[1])
	end

	local nextItems = {}
	local nextSlots = {}
	local occupied = {}

	for _, payloadItem in ipairs(ordered) do
		local itemId = tostring(payloadItem.id or "")
		local definition = InventoryDefinitions.getItem(itemId)
		local weight = math.clamp(tonumber(payloadItem.weight) or definition.weight or 1, 1, capacity)
		local slotStart = tonumber(payloadItem.slotStart)
		local slotEnd = tonumber(payloadItem.slotEnd)

		if itemId == FLASHLIGHT_ITEM_ID then
			slotStart = 1
			slotEnd = 1
		elseif not slotStart then
			slotStart = findContiguousSlot(weight, occupied)
			slotEnd = if slotStart then slotStart + weight - 1 else nil
		end

		if slotStart and slotEnd and slotEnd <= capacity then
			for slot = slotStart, slotEnd do
				occupied[slot] = true
			end

			local item = {
				id = itemId,
				name = tostring(payloadItem.name or definition.name or itemId),
				weight = weight,
				color = definition.color,
				slotStart = slotStart,
				slotEnd = slotEnd,
				slotLabel = tostring(payloadItem.slotLabel or makeSlotLabel(slotStart, slotEnd)),
			}
			table.insert(nextItems, item)

			for slot = slotStart, slotEnd do
				nextSlots[slot] = item
			end
		end
	end

	items = nextItems
	slots = nextSlots

	if not hasEquippedItem() then
		equippedItemId = FLASHLIGHT_ITEM_ID
		equippedSlot = 1
	else
		local item = EquipmentClient.getItem(equippedItemId)
		equippedSlot = item and item.slotStart or 1
	end

	notify()
end

-- Initializes inventory state, slot hotkeys, and server inventory updates.
function EquipmentClient.init()
	if initialized then return end
	initialized = true

	applyPayload(defaultPayload)

	local inventoryEvent = ReplicatedStorage:WaitForChild("InventoryUpdate", 10)
	if inventoryEvent then
		inventoryEvent.OnClientEvent:Connect(applyPayload)
	end

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end

		local slot = SLOT_KEYCODES[input.KeyCode]
		if slot then
			EquipmentClient.equipSlot(slot)
		end
	end)
end

-- Registers a listener that receives equipment state snapshots.
function EquipmentClient.onChanged(listener)
	table.insert(listeners, listener)
	listener({
		capacity = capacity,
		items = items,
		slots = slots,
		equippedItemId = equippedItemId,
		equippedSlot = equippedSlot,
	})

	return function()
		for index, existing in ipairs(listeners) do
			if existing == listener then
				table.remove(listeners, index)
				break
			end
		end
	end
end

-- Equips the item occupying a numbered inventory slot.
function EquipmentClient.equipSlot(slot: number): boolean
	local item = slots[slot]
	if not item then
		return false
	end

	if equippedItemId == item.id then
		return true
	end

	equippedItemId = item.id
	equippedSlot = item.slotStart or slot
	notify()
	return true
end

-- Equips a held item by ID when it is present in inventory.
function EquipmentClient.equipItem(itemId: string): boolean
	local item = EquipmentClient.getItem(itemId)
	if not item then
		return false
	end

	equippedItemId = item.id
	equippedSlot = item.slotStart or 1
	notify()
	return true
end

-- Returns the current inventory item payload for an item ID.
function EquipmentClient.getItem(itemId: string)
	for _, item in ipairs(items) do
		if item.id == itemId then
			return item
		end
	end
	return nil
end

-- Returns whether the current inventory contains an item ID.
function EquipmentClient.hasItem(itemId: string): boolean
	return EquipmentClient.getItem(itemId) ~= nil
end

-- Returns the ordered current inventory items.
function EquipmentClient.getItems()
	return items
end

-- Returns the current slot-to-item map.
function EquipmentClient.getSlots()
	return slots
end

-- Returns the equipped item ID.
function EquipmentClient.getEquippedItemId(): string
	return equippedItemId
end

-- Returns the equipped starting slot.
function EquipmentClient.getEquippedSlot(): number
	return equippedSlot
end

-- Returns whether an item ID is currently equipped.
function EquipmentClient.isEquipped(itemId: string): boolean
	return equippedItemId == itemId
end

return EquipmentClient
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="34">
          <Properties>
            <string name="Name">Flashlight</string>
            <string name="Source"><![CDATA[-- Battery-powered flashlight with limited runtime and toggle
local Flashlight = {}

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local SoundService = game:GetService("SoundService")
local Debris = game:GetService("Debris")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Constants = require(ReplicatedStorage.Shared.Constants)
local EquipmentClient = require(script.Parent.EquipmentClient)

-- Constants
local CLIENT_WAIT_TIMEOUT = Constants.REMOTE_LIMITS.CLIENT_WAIT_TIMEOUT
local GAMEPLAY_ITEMS_FOLDER_NAME = Constants.OBJECTIVES.GAMEPLAY_ITEMS_FOLDER_NAME
local MAX_BATTERY = 60 -- 60 seconds of total flashlight usage
local FULL_BRIGHTNESS = 5.25
local FULL_RANGE = 40
local CLOSE_FILL_BRIGHTNESS = 0.55
local CLOSE_FILL_RANGE = 10
local SURFACE_FILL_BRIGHTNESS = 1.05
local SURFACE_FILL_RANGE = 16
local SPOT_ANGLE = 54
local DIMMING_THRESHOLD = 12 -- last 12 seconds = dimming phase
local VIEWMODEL_TEMPLATE_NAME = "Flashlight"
local VIEWMODEL_SCALE = 0.14
local VIEWMODEL_OFFSET = CFrame.new(0.58, -0.66, -1.12) * CFrame.Angles(math.rad(-4), math.rad(92), math.rad(-9))
local VIEWMODEL_HIDDEN_OFFSET = CFrame.new(0.34, -1.18, 0.48) * CFrame.Angles(math.rad(22), math.rad(-12), math.rad(-18))
local LIGHT_EMITTER_OFFSET = CFrame.new(0.44, -0.52, -1.58)
local HAND_SKIN_COLOR = Color3.fromRGB(180, 132, 96)
local SLEEVE_COLOR = Color3.fromRGB(34, 35, 38)
local EQUIP_ANIMATION_TIME = 0.38
local UNEQUIP_ANIMATION_TIME = 0.3
local TOGGLE_COOLDOWN = 0.32
local FLASHLIGHT_REPORT_RATE = 0.08
local REMOTE_STALE_TIME = 0.35
local REMOTE_BEAM_LENGTH = 26
local REMOTE_BEAM_THICKNESS = 0.2
local FLASHLIGHT_CLICK_SOUND_ID = "rbxasset://sounds/switch.wav"

-- State
local battery = MAX_BATTERY
local flashlightPart: Part? = nil
local flashlightViewModel: Model? = nil
local handViewModel: Model? = nil
local handParts = {}
local flashlightSpot: SpotLight? = nil
local flashlightFill: PointLight? = nil
local surfaceFillPart: Part? = nil
local surfaceFillLight: PointLight? = nil
local batteryConnection: RBXScriptConnection? = nil
local isDead = false
local isOn = true
local isEquipped = true
local hudFrame: Frame? = nil
local hudStatus: TextLabel? = nil
local hudBatteryText: TextLabel? = nil
local hudBatteryFill: Frame? = nil
local lastToggleTime = -math.huge
local viewmodelAlpha = 1
local viewmodelStartAlpha = 1
local viewmodelTargetAlpha = 1
local viewmodelAnimationTime = 0
local viewmodelAnimationDuration = 0
local viewModelSuppressed = false
local flashlightStateEvent: RemoteEvent? = nil
local reportTimer = 0
local remoteFlashlights = {}

local function addTextStroke(label: TextLabel, transparency: number)
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.TextStrokeTransparency = transparency
end

local function smoothStep(alpha: number): number
	local clamped = math.clamp(alpha, 0, 1)
	return clamped * clamped * (3 - (2 * clamped))
end

local function setViewModelParent(parent: Instance?)
	if flashlightViewModel and flashlightViewModel.Parent ~= parent then
		flashlightViewModel.Parent = parent
	end
	if handViewModel and handViewModel.Parent ~= parent then
		handViewModel.Parent = parent
	end
end

local function setLightsEnabled(enabled: boolean)
	if flashlightSpot then
		flashlightSpot.Enabled = enabled
	end
	if flashlightFill then
		flashlightFill.Enabled = enabled
	end
	if surfaceFillLight then
		surfaceFillLight.Enabled = enabled
	end
end

local function shouldEmitLight(): boolean
	return isEquipped and isOn and not isDead
end

local function applyEquippedVisibility()
	setLightsEnabled(shouldEmitLight())
	if hudFrame then
		hudFrame.Visible = isEquipped
	end
end

local function playClickSound(turningOn: boolean)
	local sound = Instance.new("Sound")
	sound.Name = "FlashlightClick"
	sound.SoundId = FLASHLIGHT_CLICK_SOUND_ID
	sound.Volume = 0.14
	sound.PlaybackSpeed = (if turningOn then 1.04 else 0.92) + (math.random() * 0.04)
	sound.Parent = SoundService
	sound:Play()
	Debris:AddItem(sound, 1.5)
end

local function startViewModelTransition(show: boolean)
	viewmodelStartAlpha = viewmodelAlpha
	viewmodelTargetAlpha = if show then 1 else 0
	viewmodelAnimationTime = 0
	viewmodelAnimationDuration = if show then EQUIP_ANIMATION_TIME else UNEQUIP_ANIMATION_TIME
end

local function updateViewModelAnimation(dt: number)
	if viewmodelAlpha == viewmodelTargetAlpha then
		return
	end

	viewmodelAnimationTime += dt
	local alpha = smoothStep(viewmodelAnimationTime / math.max(viewmodelAnimationDuration, 0.01))
	viewmodelAlpha = viewmodelStartAlpha + ((viewmodelTargetAlpha - viewmodelStartAlpha) * alpha)

	if viewmodelAnimationTime >= viewmodelAnimationDuration then
		viewmodelAlpha = viewmodelTargetAlpha
	end
end

local function getAnimatedViewModelOffset(): CFrame
	local pose = VIEWMODEL_HIDDEN_OFFSET:Lerp(CFrame.identity, smoothStep(viewmodelAlpha))
	if viewmodelAnimationTime > 0 and viewmodelAnimationTime < viewmodelAnimationDuration then
		local phase = math.clamp(viewmodelAnimationTime / viewmodelAnimationDuration, 0, 1)
		local flick = math.sin(phase * math.pi)
		local direction = if viewmodelTargetAlpha > viewmodelStartAlpha then 1 else -1
		pose *= CFrame.new(0, 0.03 * flick, -0.04 * flick * direction)
			* CFrame.Angles(math.rad(-5 * flick * direction), math.rad(2 * flick), math.rad(5 * flick * direction))
	end

	return pose
end

local function prepareViewModel(model: Model)
	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			descendant.Anchored = true
			descendant.CanCollide = false
			descendant.CanQuery = false
			descendant.CanTouch = false
			descendant.CastShadow = false
			descendant.Massless = true
		elseif descendant:IsA("Script") or descendant:IsA("LocalScript") then
			descendant:Destroy()
		end
	end
end

local function findFlashlightTemplate(): Model?
	local gameplayItems = workspace:FindFirstChild(GAMEPLAY_ITEMS_FOLDER_NAME)
	local template = gameplayItems and gameplayItems:FindFirstChild(VIEWMODEL_TEMPLATE_NAME)
	if not template then
		template = workspace:FindFirstChild(VIEWMODEL_TEMPLATE_NAME, true)
	end

	if template and template:IsA("Model") then
		return template
	end

	return nil
end

local function createFlashlightViewModel(camera: Camera?): Model?
	local template = findFlashlightTemplate()
	if not template then
		warn("Flashlight model not found in Workspace.GameplayItems or workspace descendants. Falling back to light-only flashlight.")
		return nil
	end

	local viewModel = template:Clone()
	viewModel.Name = "FirstPersonFlashlight"
	prepareViewModel(viewModel)

	local scaled = pcall(function()
		viewModel:ScaleTo(VIEWMODEL_SCALE)
	end)
	if not scaled then
		warn("Unable to scale flashlight viewmodel; using authored size.")
	end

	viewModel.Parent = camera or workspace
	return viewModel
end

local function createHandPart(name: string, shape: Enum.PartType, size: Vector3, color: Color3, offset: CFrame): Part
	local part = Instance.new("Part")
	part.Name = name
	part.Shape = shape
	part.Size = size
	part.Color = color
	part.Material = Enum.Material.SmoothPlastic
	part.Anchored = true
	part.CanCollide = false
	part.CanQuery = false
	part.CanTouch = false
	part.CastShadow = false
	part.Massless = true
	part.Parent = handViewModel
	table.insert(handParts, {
		part = part,
		offset = offset,
	})
	return part
end

local function createHandViewModel(camera: Camera?): Model
	local model = Instance.new("Model")
	model.Name = "FirstPersonFlashlightHand"
	model.Parent = camera or workspace
	handViewModel = model
	table.clear(handParts)

	createHandPart(
		"Sleeve",
		Enum.PartType.Block,
		Vector3.new(0.22, 0.2, 0.28),
		SLEEVE_COLOR,
		CFrame.new(0.88, -1.1, -0.54) * CFrame.Angles(math.rad(-18), math.rad(-10), math.rad(8))
	)
	createHandPart(
		"Forearm",
		Enum.PartType.Block,
		Vector3.new(0.16, 0.16, 0.32),
		HAND_SKIN_COLOR,
		CFrame.new(0.74, -0.92, -0.78) * CFrame.Angles(math.rad(-18), math.rad(-14), math.rad(8))
	)
	createHandPart(
		"Hand",
		Enum.PartType.Ball,
		Vector3.new(0.22, 0.17, 0.18),
		HAND_SKIN_COLOR,
		CFrame.new(0.58, -0.7, -1.1) * CFrame.Angles(math.rad(-6), math.rad(-18), math.rad(4))
	)
	createHandPart(
		"Thumb",
		Enum.PartType.Block,
		Vector3.new(0.07, 0.09, 0.14),
		HAND_SKIN_COLOR,
		CFrame.new(0.46, -0.69, -1.05) * CFrame.Angles(math.rad(18), math.rad(28), math.rad(-12))
	)

	return model
end

local function disableLocalCharacterShadows(character: Model)
	for _, descendant in ipairs(character:GetDescendants()) do
		if descendant:IsA("BasePart") then
			descendant.CastShadow = false
		end
	end

	character.DescendantAdded:Connect(function(descendant)
		if descendant:IsA("BasePart") then
			descendant.CastShadow = false
		end
	end)
end

local function createSurfaceFillLight(): (Part, PointLight)
	local part = Instance.new("Part")
	part.Name = "FlashlightSurfaceFillEmitter"
	part.Shape = Enum.PartType.Ball
	part.Size = Vector3.new(0.16, 0.16, 0.16)
	part.Transparency = 1
	part.Anchored = true
	part.CanCollide = false
	part.CanQuery = false
	part.CanTouch = false
	part.CastShadow = false
	part.Parent = workspace

	local light = Instance.new("PointLight")
	light.Name = "FlashlightSurfaceFill"
	light.Brightness = SURFACE_FILL_BRIGHTNESS
	light.Range = SURFACE_FILL_RANGE
	light.Shadows = false
	light.Color = Color3.fromRGB(255, 240, 210)
	light.Enabled = shouldEmitLight()
	light.Parent = part

	return part, light
end

-- Create the held local flashlight and lights that follow its muzzle.
function Flashlight.createFlashlight(): (Part, SpotLight)
	local camera = workspace.CurrentCamera
	flashlightViewModel = createFlashlightViewModel(camera)
	createHandViewModel(camera)

	local part = Instance.new("Part")
	part.Name = "FlashlightEmitter"
	part.Shape = Enum.PartType.Block
	part.Size = Vector3.new(0.12, 0.12, 0.12)
	part.Transparency = 1 -- invisible
	part.CanCollide = false
	part.CanQuery = false
	part.CanTouch = false
	part.Anchored = true
	part.CastShadow = false
	part.Parent = workspace

	local spotLight = Instance.new("SpotLight")
	spotLight.Name = "FlashlightBeam"
	spotLight.Brightness = FULL_BRIGHTNESS
	spotLight.Range = FULL_RANGE
	spotLight.Angle = SPOT_ANGLE
	spotLight.Shadows = true
	spotLight.Color = Color3.fromRGB(255, 245, 220) -- Warm white
	spotLight.Face = Enum.NormalId.Front
	spotLight.Enabled = shouldEmitLight()
	spotLight.Parent = part

	local fillLight = Instance.new("PointLight")
	fillLight.Name = "FlashlightCloseFill"
	fillLight.Brightness = CLOSE_FILL_BRIGHTNESS
	fillLight.Range = CLOSE_FILL_RANGE
	fillLight.Shadows = false
	fillLight.Color = Color3.fromRGB(255, 240, 210)
	fillLight.Enabled = shouldEmitLight()
	fillLight.Parent = part
	flashlightFill = fillLight
	surfaceFillPart, surfaceFillLight = createSurfaceFillLight()

	return part, spotLight
end

local function updateFlashlightTransform(camera: Camera, dt: number)
	updateViewModelAnimation(dt)

	if flashlightPart then
		if flashlightPart.Parent ~= workspace then
			flashlightPart.Parent = workspace
		end
		flashlightPart.CFrame = camera.CFrame * LIGHT_EMITTER_OFFSET
	end

	if surfaceFillPart and surfaceFillLight then
		if shouldEmitLight() then
			local params = RaycastParams.new()
			params.FilterType = Enum.RaycastFilterType.Exclude
			local ignored = { flashlightPart, surfaceFillPart, flashlightViewModel, handViewModel }
			local character = Players.LocalPlayer.Character
			if character then
				table.insert(ignored, character)
			end
			params.FilterDescendantsInstances = ignored
			params.IgnoreWater = true

			local result = workspace:Raycast(camera.CFrame.Position, camera.CFrame.LookVector * FULL_RANGE, params)
			if result then
				local distanceAlpha = math.clamp(1 - (result.Distance / FULL_RANGE), 0, 1)
				surfaceFillPart.Position = result.Position + (result.Normal * 0.18)
				surfaceFillLight.Enabled = true
				surfaceFillLight.Brightness = SURFACE_FILL_BRIGHTNESS * (0.35 + (distanceAlpha * 0.65))
				surfaceFillLight.Range = SURFACE_FILL_RANGE * (0.55 + (distanceAlpha * 0.45))
			else
				surfaceFillLight.Enabled = false
			end
		else
			surfaceFillLight.Enabled = false
		end
	end

	local shouldShowViewModel = not viewModelSuppressed and (isEquipped or viewmodelAlpha > 0.01 or viewmodelTargetAlpha > 0)
	setViewModelParent(if shouldShowViewModel then camera else nil)
	local animatedOffset = getAnimatedViewModelOffset()

	if flashlightViewModel and flashlightViewModel.Parent then
		flashlightViewModel:PivotTo(camera.CFrame * animatedOffset * VIEWMODEL_OFFSET)
	end
	for _, data in ipairs(handParts) do
		if data.part and data.part.Parent then
			data.part.CFrame = camera.CFrame * animatedOffset * data.offset
		end
	end
end

-- Create HUD in bottom-right corner
function Flashlight.createHUD()
	local player = Players.LocalPlayer
	local playerGui = player:FindFirstChild("PlayerGui") or player:WaitForChild("PlayerGui", CLIENT_WAIT_TIMEOUT)
	if not playerGui then
		warn("[Flashlight] PlayerGui was not available; flashlight HUD disabled.")
		return
	end

	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "FlashlightHUD"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = playerGui

	local frame = Instance.new("Frame")
	frame.Name = "HudFrame"
	frame.Size = UDim2.new(0, 252, 0, 86)
	frame.AnchorPoint = Vector2.new(1, 1)
	frame.Position = UDim2.new(1, -24, 1, -30)
	frame.BackgroundTransparency = 1
	frame.BorderSizePixel = 0
	frame.Visible = isEquipped
	frame.Parent = screenGui

	local diamond = Instance.new("Frame")
	diamond.Name = "Diamond"
	diamond.Size = UDim2.new(0, 22, 0, 22)
	diamond.Position = UDim2.new(0, 0, 0, 8)
	diamond.BackgroundTransparency = 1
	diamond.Rotation = 45
	diamond.Parent = frame

	local diamondStroke = Instance.new("UIStroke")
	diamondStroke.Color = Color3.fromRGB(185, 186, 178)
	diamondStroke.Transparency = 0.22
	diamondStroke.Thickness = 1
	diamondStroke.Parent = diamond

	local innerDiamond = Instance.new("Frame")
	innerDiamond.Name = "InnerDiamond"
	innerDiamond.Size = UDim2.new(0, 10, 0, 10)
	innerDiamond.Position = UDim2.new(0.5, -5, 0.5, -5)
	innerDiamond.BackgroundTransparency = 1
	innerDiamond.Parent = diamond

	local innerStroke = Instance.new("UIStroke")
	innerStroke.Color = Color3.fromRGB(126, 28, 28)
	innerStroke.Transparency = 0.2
	innerStroke.Thickness = 1
	innerStroke.Parent = innerDiamond

	local title = Instance.new("TextLabel")
	title.Name = "Title"
	title.Size = UDim2.new(1, -38, 0, 24)
	title.Position = UDim2.new(0, 34, 0, 3)
	title.BackgroundTransparency = 1
	title.Font = Enum.Font.Garamond
	title.Text = "Flashlight"
	title.TextColor3 = Color3.fromRGB(232, 230, 220)
	title.TextSize = 22
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = frame
	addTextStroke(title, 0.55)

	local status = Instance.new("TextLabel")
	status.Name = "Status"
	status.Size = UDim2.new(0, 72, 0, 20)
	status.Position = UDim2.new(0, 34, 0, 29)
	status.BackgroundTransparency = 1
	status.Font = Enum.Font.GothamMedium
	status.TextColor3 = Color3.fromRGB(198, 196, 186)
	status.TextSize = 13
	status.TextXAlignment = Enum.TextXAlignment.Left
	status.TextYAlignment = Enum.TextYAlignment.Top
	status.Parent = frame
	addTextStroke(status, 0.68)

	local hint = Instance.new("TextLabel")
	hint.Name = "Hint"
	hint.Size = UDim2.new(1, -112, 0, 20)
	hint.Position = UDim2.new(0, 110, 0, 29)
	hint.BackgroundTransparency = 1
	hint.Font = Enum.Font.Gotham
	hint.Text = "F Toggle"
	hint.TextColor3 = Color3.fromRGB(150, 148, 140)
	hint.TextSize = 12
	hint.TextXAlignment = Enum.TextXAlignment.Left
	hint.TextYAlignment = Enum.TextYAlignment.Top
	hint.Parent = frame
	addTextStroke(hint, 0.75)

	local batteryTrack = Instance.new("Frame")
	batteryTrack.Name = "BatteryTrack"
	batteryTrack.Size = UDim2.new(1, -38, 0, 3)
	batteryTrack.Position = UDim2.new(0, 34, 0, 57)
	batteryTrack.BackgroundColor3 = Color3.fromRGB(72, 71, 67)
	batteryTrack.BackgroundTransparency = 0.35
	batteryTrack.BorderSizePixel = 0
	batteryTrack.Parent = frame

	local batteryFill = Instance.new("Frame")
	batteryFill.Name = "BatteryFill"
	batteryFill.Size = UDim2.new(1, 0, 1, 0)
	batteryFill.BackgroundColor3 = Color3.fromRGB(208, 205, 190)
	batteryFill.BorderSizePixel = 0
	batteryFill.Parent = batteryTrack

	local batteryText = Instance.new("TextLabel")
	batteryText.Name = "Battery"
	batteryText.Size = UDim2.new(1, -38, 0, 18)
	batteryText.Position = UDim2.new(0, 34, 0, 64)
	batteryText.BackgroundTransparency = 1
	batteryText.Font = Enum.Font.Gotham
	batteryText.TextColor3 = Color3.fromRGB(170, 168, 158)
	batteryText.TextSize = 12
	batteryText.TextXAlignment = Enum.TextXAlignment.Left
	batteryText.TextYAlignment = Enum.TextYAlignment.Top
	batteryText.Parent = frame
	addTextStroke(batteryText, 0.75)

	hudFrame = frame
	hudStatus = status
	hudBatteryText = batteryText
	hudBatteryFill = batteryFill
end

-- Update HUD text
function Flashlight.updateHUD()
	if not hudStatus or not hudBatteryText or not hudBatteryFill then return end

	local batteryPercent = math.floor((battery / MAX_BATTERY) * 100)
	local flashlightStatus = if isDead then "DEAD" else (if isOn then "ON" else "OFF")
	local warningColor = Color3.fromRGB(148, 42, 42)
	local normalColor = Color3.fromRGB(198, 196, 186)
	local dimColor = Color3.fromRGB(126, 124, 116)
	local statusColor = if isDead then warningColor else (if isOn then normalColor else dimColor)
	local batteryColor = if batteryPercent > 30 then Color3.fromRGB(208, 205, 190) else warningColor

	hudStatus.Text = flashlightStatus
	hudStatus.TextColor3 = statusColor
	hudBatteryText.Text = string.format("Battery  %d%%", batteryPercent)
	hudBatteryText.TextColor3 = batteryColor
	hudBatteryFill.Size = UDim2.new(math.clamp(battery / MAX_BATTERY, 0, 1), 0, 1, 0)
	hudBatteryFill.BackgroundColor3 = batteryColor
end

-- Toggle flashlight on/off
function Flashlight.toggle()
	if isDead or not isEquipped or viewModelSuppressed then return end
	local now = os.clock()
	if now - lastToggleTime < TOGGLE_COOLDOWN then
		return
	end
	lastToggleTime = now

	isOn = not isOn
	playClickSound(isOn)
	applyEquippedVisibility()

	print("🔦 Flashlight", if isOn then "ON" else "OFF")
	Flashlight.updateHUD()
end

-- Suppresses or restores the first-person flashlight model without changing equipment state.
function Flashlight.setViewModelSuppressed(suppressed: boolean)
	viewModelSuppressed = suppressed == true
	if viewModelSuppressed then
		setViewModelParent(nil)
	end
end

-- Applies whether the flashlight item is currently equipped.
function Flashlight.setEquipped(equipped: boolean)
	local nextEquipped = equipped == true
	if isEquipped == nextEquipped then
		applyEquippedVisibility()
		return
	end

	isEquipped = nextEquipped
	startViewModelTransition(isEquipped)
	applyEquippedVisibility()
end

local function createRemoteFlashlight()
	local model = Instance.new("Model")
	model.Name = "RemoteFlashlight"
	model.Parent = workspace

	local emitter = Instance.new("Part")
	emitter.Name = "RemoteFlashlightEmitter"
	emitter.Size = Vector3.new(0.16, 0.16, 0.16)
	emitter.Transparency = 1
	emitter.Anchored = true
	emitter.CanCollide = false
	emitter.CanTouch = false
	emitter.CanQuery = false
	emitter.CastShadow = false
	emitter.Parent = model

	local light = Instance.new("SpotLight")
	light.Name = "RemoteFlashlightBeam"
	light.Angle = SPOT_ANGLE
	light.Brightness = FULL_BRIGHTNESS * 0.55
	light.Range = FULL_RANGE
	light.Shadows = true
	light.Color = Color3.fromRGB(255, 245, 220)
	light.Face = Enum.NormalId.Front
	light.Parent = emitter

	local beam = Instance.new("Part")
	beam.Name = "RemoteFlashlightRay"
	beam.Size = Vector3.new(REMOTE_BEAM_THICKNESS, REMOTE_BEAM_THICKNESS, REMOTE_BEAM_LENGTH)
	beam.Transparency = 0.78
	beam.Anchored = true
	beam.CanCollide = false
	beam.CanTouch = false
	beam.CanQuery = false
	beam.CastShadow = false
	beam.Material = Enum.Material.Neon
	beam.Color = Color3.fromRGB(255, 244, 206)
	beam.Parent = model

	return {
		model = model,
		emitter = emitter,
		light = light,
		beam = beam,
		lastSeen = os.clock(),
	}
end

local function destroyRemoteFlashlight(sourceUserId: string)
	local remote = remoteFlashlights[sourceUserId]
	if remote then
		if remote.model then
			remote.model:Destroy()
		end
		remoteFlashlights[sourceUserId] = nil
	end
end

local function handleRemoteFlashlight(payload)
	if typeof(payload) ~= "table" then return end
	if tonumber(payload.sourceUserId) == Players.LocalPlayer.UserId then return end

	local sourceUserId = tostring(payload.sourceUserId or "")
	if sourceUserId == "" then return end

	if payload.enabled ~= true then
		destroyRemoteFlashlight(sourceUserId)
		return
	end

	local origin = payload.origin
	local direction = payload.direction
	if typeof(origin) ~= "Vector3" or typeof(direction) ~= "Vector3" or direction.Magnitude <= 0 then
		destroyRemoteFlashlight(sourceUserId)
		return
	end

	local remote = remoteFlashlights[sourceUserId]
	if not remote then
		remote = createRemoteFlashlight()
		remoteFlashlights[sourceUserId] = remote
	end

	local unitDirection = direction.Unit
	local range = math.clamp(tonumber(payload.range) or FULL_RANGE, 8, FULL_RANGE)
	local brightnessScale = math.clamp(tonumber(payload.brightnessScale) or 1, 0.1, 1)
	local beamLength = math.min(REMOTE_BEAM_LENGTH, range)
	local beamCenter = origin + (unitDirection * (beamLength * 0.5))

	remote.lastSeen = os.clock()
	remote.emitter.CFrame = CFrame.lookAt(origin, origin + unitDirection)
	remote.light.Brightness = FULL_BRIGHTNESS * 0.55 * brightnessScale
	remote.light.Range = range
	remote.light.Enabled = true
	remote.beam.Size = Vector3.new(REMOTE_BEAM_THICKNESS, REMOTE_BEAM_THICKNESS, beamLength)
	remote.beam.CFrame = CFrame.lookAt(beamCenter, beamCenter + unitDirection)
	remote.beam.Transparency = 0.82 - (0.18 * brightnessScale)
end

local function updateRemoteFlashlights()
	local now = os.clock()
	for sourceUserId, remote in pairs(remoteFlashlights) do
		if now - (remote.lastSeen or 0) > REMOTE_STALE_TIME then
			destroyRemoteFlashlight(sourceUserId)
		end
	end
end

local function reportFlashlightState(dt: number)
	if not flashlightStateEvent then return end

	reportTimer += dt
	if reportTimer < FLASHLIGHT_REPORT_RATE then
		return
	end
	reportTimer = 0

	local enabled = shouldEmitLight()
	local camera = workspace.CurrentCamera
	local origin = flashlightPart and flashlightPart.Position
	local direction = camera and camera.CFrame.LookVector
	local brightnessScale = math.clamp(battery / MAX_BATTERY, 0, 1)

	if enabled and battery < DIMMING_THRESHOLD then
		brightnessScale = math.clamp(battery / DIMMING_THRESHOLD, 0.1, 1)
	end

	flashlightStateEvent:FireServer({
		enabled = enabled,
		origin = origin,
		direction = direction,
		range = flashlightSpot and flashlightSpot.Range or FULL_RANGE,
		brightnessScale = brightnessScale,
	})
end

-- Initializes flashlight input, viewmodel, lights, HUD, and remote replication.
function Flashlight.init()
	print("🔦 Flashlight initializing...")

	EquipmentClient.init()
	flashlightStateEvent = ReplicatedStorage:WaitForChild("FlashlightState", CLIENT_WAIT_TIMEOUT)
	flashlightPart, flashlightSpot = Flashlight.createFlashlight()

	local player = Players.LocalPlayer
	if player.Character then
		disableLocalCharacterShadows(player.Character)
	end
	player.CharacterAdded:Connect(disableLocalCharacterShadows)

	-- Create HUD
	Flashlight.createHUD()
	Flashlight.updateHUD()
	applyEquippedVisibility()

	EquipmentClient.onChanged(function(state)
		Flashlight.setEquipped(state.equippedItemId == "Flashlight")
	end)

	if flashlightStateEvent then
		flashlightStateEvent.OnClientEvent:Connect(handleRemoteFlashlight)
	end

	-- Listen for F key to toggle flashlight
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode == Enum.KeyCode.F then
			Flashlight.toggle()
		end
	end)

	-- Start battery depletion + HUD update + camera-sync loop (runs every frame)
	local hudTimer = 0
	batteryConnection = RunService.RenderStepped:Connect(function(dt)
		local camera = workspace.CurrentCamera
		if flashlightPart and camera then
			updateFlashlightTransform(camera, dt)
		end

		Flashlight.updateBattery(dt)
		reportFlashlightState(dt)
		updateRemoteFlashlights()

		-- Update HUD text every 0.5s to avoid spam
		hudTimer = hudTimer + dt
		if hudTimer >= 0.5 then
			hudTimer = 0
			Flashlight.updateHUD()
		end
	end)

	print(string.format("🔦 Flashlight ready (%.0f seconds of battery)", MAX_BATTERY))
	Flashlight.updateHUD()
end

-- Depletes battery each frame while the flashlight is on and equipped.
function Flashlight.updateBattery(dt: number)
	if not flashlightSpot or isDead then return end

	if isEquipped and isOn then
		battery = math.max(0, battery - dt)

		-- Dim the flashlight during the last 12 seconds as a warning
		if battery < DIMMING_THRESHOLD and battery > 0 then
			local ratio = math.max(0, battery / DIMMING_THRESHOLD)
			flashlightSpot.Brightness = FULL_BRIGHTNESS * ratio
			flashlightSpot.Range = (FULL_RANGE * 0.5) + (FULL_RANGE * 0.5 * ratio)
			if flashlightFill then
				flashlightFill.Brightness = CLOSE_FILL_BRIGHTNESS * ratio
				flashlightFill.Range = (CLOSE_FILL_RANGE * 0.55) + (CLOSE_FILL_RANGE * 0.45 * ratio)
			end
		elseif battery > 0 then
			flashlightSpot.Brightness = FULL_BRIGHTNESS
			flashlightSpot.Range = FULL_RANGE
			if flashlightFill then
				flashlightFill.Brightness = CLOSE_FILL_BRIGHTNESS
				flashlightFill.Range = CLOSE_FILL_RANGE
			end
		elseif battery <= 0 then
			isDead = true
			isOn = false
			applyEquippedVisibility()
			Flashlight.updateHUD()
			print("🔋 Flashlight battery depleted!")
		end
	end
end

-- Cleans up flashlight viewmodel, lights, HUD, and frame connections.
function Flashlight.destroy()
	if batteryConnection then
		batteryConnection:Disconnect()
		batteryConnection = nil
	end
	if flashlightPart then
		flashlightPart:Destroy()
		flashlightPart = nil
		flashlightSpot = nil
		flashlightFill = nil
	end
	if surfaceFillPart then
		surfaceFillPart:Destroy()
		surfaceFillPart = nil
		surfaceFillLight = nil
	end
	if flashlightViewModel then
		flashlightViewModel:Destroy()
		flashlightViewModel = nil
	end
	if handViewModel then
		handViewModel:Destroy()
		handViewModel = nil
	end
	table.clear(handParts)
	if hudFrame then
		hudFrame.Parent = nil
		hudFrame:Destroy()
		hudFrame = nil
		hudStatus = nil
		hudBatteryText = nil
		hudBatteryFill = nil
	end
end

-- Returns the current remaining battery seconds.
function Flashlight.getBattery(): number
	return battery
end

-- Returns the maximum battery seconds.
function Flashlight.getMaxBattery(): number
	return MAX_BATTERY
end

-- Returns whether the battery is depleted.
function Flashlight.getIsDead(): boolean
	return isDead
end

-- Returns whether the flashlight beam should currently be visible.
function Flashlight.getIsOn(): boolean
	return isEquipped and isOn
end

-- Returns whether the flashlight item is currently equipped.
function Flashlight.getIsEquipped(): boolean
	return isEquipped
end

return Flashlight
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="35">
          <Properties>
            <string name="Name">InputHandler</string>
            <string name="Source"><![CDATA[-- Client-side input handler for movement state, microphone volume, and noise events
local InputHandler = {}

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local VoiceChatService = game:GetService("VoiceChatService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Constants = require(game.ReplicatedStorage.Shared.Constants)

local player = Players.LocalPlayer
local movementSpeed = 0
local micVolume = 0
local audioAnalyzer = nil
local activePulseSphere = nil
local initialized = false
local isCrouching = false
local isSprinting = false
local jumpNoiseUntil = 0
local lastReportTime = 0
local REPORT_RATE = 0.1
local NOISE_THRESHOLD = 0.025
local VOICE_ACTIVITY_THRESHOLD = 0.008
local MIC_GAIN = 42
local MIC_NOISE_FLOOR = 0.0002
local MIC_RESPONSE_POWER = 0.72
local MOVEMENT_VISUAL_INTENSITY_SCALE = 0.3
local MOVEMENT_VISUAL_RADIUS_SCALE = 0.3
local DEFAULT_WALK_SPEED = 12

local currentNoise = {
	intensity = 0,
	radius = 0,
	monsterRisk = 0,
	movementState = "idle",
	hasVoice = false,
	voiceVolume = 0,
}

local function setSilentNoise()
	movementSpeed = 0
	micVolume = 0
	currentNoise = {
		intensity = 0,
		radius = 0,
		monsterRisk = 0,
		movementState = "idle",
		hasVoice = false,
		voiceVolume = 0,
	}
end

function InputHandler.getMovementSpeed(): number
	return movementSpeed
end

function InputHandler.getMicVolume(): number
	return micVolume
end

function InputHandler.getNoiseInfo()
	return currentNoise
end

local function setHumanoidSpeed(humanoid: Humanoid)
	if isCrouching then
		humanoid.WalkSpeed = Constants.MOVEMENT_NOISE.crouch.walkSpeed
	elseif isSprinting then
		humanoid.WalkSpeed = Constants.MOVEMENT_NOISE.sprint.walkSpeed
	else
		humanoid.WalkSpeed = Constants.MOVEMENT_NOISE.walk.walkSpeed or DEFAULT_WALK_SPEED
	end
end

local function getMovementState(humanoid: Humanoid?): string
	if not humanoid or movementSpeed < 0.1 then
		return "idle"
	end

	if os.clock() < jumpNoiseUntil then
		return "jump"
	end

	if isCrouching then
		return "crouch"
	end

	if isSprinting then
		return "sprint"
	end

	return "walk"
end

local function calculateNoise(humanoid: Humanoid?)
	local movementState = getMovementState(humanoid)
	local movementTier = Constants.MOVEMENT_NOISE[movementState] or Constants.MOVEMENT_NOISE.idle
	local movementVisualIntensity = movementTier.intensity * MOVEMENT_VISUAL_INTENSITY_SCALE
	local movementVisualRadius = movementTier.radius * MOVEMENT_VISUAL_RADIUS_SCALE
	local voiceIntensity = micVolume * Constants.VOICE_NOISE.intensityMultiplier
	local voiceRadius = micVolume * Constants.VOICE_NOISE.radiusMultiplier
	local voiceRisk = voiceIntensity * Constants.VOICE_NOISE.monsterRiskMultiplier
	local hasVoice = micVolume > VOICE_ACTIVITY_THRESHOLD

	currentNoise = {
		intensity = math.clamp(movementVisualIntensity + voiceIntensity, 0, 5),
		radius = math.clamp(movementVisualRadius + voiceRadius, 0, Constants.SPHERE_MAX_RADIUS),
		monsterRisk = math.clamp(movementTier.monsterRisk + voiceRisk, 0, 6),
		movementState = movementState,
		hasVoice = hasVoice,
		voiceVolume = micVolume,
	}
end

local function updatePulseSphere(rootPart: BasePart)
	if activePulseSphere then
		activePulseSphere:Destroy()
		activePulseSphere = nil
	end
end

local function calculateMicVolume(rawLevel: number): number
	local adjustedLevel = math.max(rawLevel - MIC_NOISE_FLOOR, 0) * MIC_GAIN
	if adjustedLevel <= 0 then
		return 0
	end

	return math.clamp(adjustedLevel ^ MIC_RESPONSE_POWER, 0, 1)
end

local function setupVoiceInput()
	local success, isVoiceEnabled = pcall(function()
		return VoiceChatService:IsVoiceEnabledForUserIdAsync(player.UserId)
	end)

	if not (success and isVoiceEnabled) then
		warn("Spatial Voice is not available or enabled for this player. Movement echolocation remains active.")
		return
	end

	local audioInput = Instance.new("AudioDeviceInput")
	audioInput.Player = player
	audioInput.Parent = player

	audioAnalyzer = Instance.new("AudioAnalyzer")
	audioAnalyzer.Parent = player

	local wire = Instance.new("Wire")
	wire.SourceInstance = audioInput
	wire.TargetInstance = audioAnalyzer
	wire.Parent = player
end

local function setupMovementKeys()
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end

		if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.C then
			isCrouching = true
			isSprinting = false
		elseif input.KeyCode == Enum.KeyCode.LeftShift then
			isSprinting = true
			isCrouching = false
		elseif input.KeyCode == Enum.KeyCode.Space then
			jumpNoiseUntil = os.clock() + Constants.MOVEMENT_NOISE.jump.duration
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.C then
			isCrouching = false
		elseif input.KeyCode == Enum.KeyCode.LeftShift then
			isSprinting = false
		end
	end)
end

function InputHandler.init()
	if initialized then return end
	initialized = true

	local pulseEvent = ReplicatedStorage:WaitForChild("EcholocationPulse", 10)
	if not pulseEvent then
		warn("EcholocationPulse RemoteEvent not found! Monster AI will be deaf.")
	end

	setupVoiceInput()
	setupMovementKeys()

	RunService.RenderStepped:Connect(function()
		if player:GetAttribute("Escaped") == true then
			setSilentNoise()
			return
		end

		local character = player.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")

		if humanoid then
			setHumanoidSpeed(humanoid)
			movementSpeed = humanoid.MoveDirection.Magnitude * humanoid.WalkSpeed
		else
			movementSpeed = 0
		end

		if audioAnalyzer then
			micVolume = calculateMicVolume(audioAnalyzer.RmsLevel)
		else
			micVolume = 0
		end

		calculateNoise(humanoid)

		if rootPart then
			updatePulseSphere(rootPart)
		end

		local currentTime = os.clock()
		if pulseEvent and currentTime - lastReportTime > REPORT_RATE then
			lastReportTime = currentTime
			pulseEvent:FireServer({
				intensity = currentNoise.monsterRisk,
				visualIntensity = currentNoise.intensity,
				radius = currentNoise.radius,
				movementState = currentNoise.movementState,
				hasVoice = currentNoise.hasVoice,
				voiceVolume = currentNoise.voiceVolume,
			})
		end
	end)
end

function InputHandler.setMicVolume(volume: number)
	micVolume = math.clamp(volume, 0, 1)
end

return InputHandler
]]></string>
